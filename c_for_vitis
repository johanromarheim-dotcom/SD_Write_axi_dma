/* main.c — ZedBoard custom data acquisition to SD card
 * Ping-pong DMA buffers + FatFs write
 * Adapted for xparameters.h defines found in BSP
 */
#include "xaxidma.h"
#include "xscugic.h"
#include "ff.h"
#include "xil_cache.h"
#include "xparameters.h"
#include <stdio.h>

/* ── Configuration ─────────────────────────────────────── */
#define DMA_DEVICE_ID    0  
#define INTC_DEVICE_ID   XPAR_SCUGIC_SINGLE_DEVICE_ID
#define DMA_S2MM_IRQ_ID  (XPAR_FABRIC_XAXIDMA_0_INTR + 32)  // = 61
#define BUFFER_BYTES     (5500 * 8)   // 5500 words x 8 bytes = 22000ns at 250MHz
#define NUM_TRANSFERS    2            // double capture
#define OUTPUT_FILE      "0:/capture.dat"

/* ── Ping-pong buffers (64-byte aligned) ────────────────── */
static u8 buf_a[BUFFER_BYTES] __attribute__((aligned(64)));
static u8 buf_b[BUFFER_BYTES] __attribute__((aligned(64)));
static u8 *dma_buf   = buf_a;
static u8 *write_buf = buf_b;

static volatile int dma_done  = 0;
static volatile int dma_error = 0;
static XAxiDma  dma;
static XScuGic  gic;
static FATFS    fs;
static FIL      fil;

/* ── DMA S2MM interrupt handler ─────────────────────────── */
void dma_s2mm_handler(void *cb)
{
    u32 status = XAxiDma_IntrGetIrq(&dma, XAXIDMA_DEVICE_TO_DMA);
    XAxiDma_IntrAckIrq(&dma, status, XAXIDMA_DEVICE_TO_DMA);
    if (status & XAXIDMA_IRQ_ERROR_MASK) { dma_error = 1; return; }
    if (status & XAXIDMA_IRQ_IOC_MASK)   { dma_done  = 1; }
}

/* ── Kick off one DMA transfer ──────────────────────────── */
static int start_dma(u8 *dst)
{
    Xil_DCacheInvalidateRange((UINTPTR)dst, BUFFER_BYTES);
    return XAxiDma_SimpleTransfer(&dma,
                (UINTPTR)dst,
                BUFFER_BYTES,
                XAXIDMA_DEVICE_TO_DMA);
}

int main(void)
{
    XAxiDma_Config *cfg;
    XScuGic_Config *gic_cfg;
    FRESULT rc;
    UINT    bw;
    u32     xfers = 0;
    u8     *tmp;

    /* ─ Init DMA ─ */
    cfg = XAxiDma_LookupConfig(DMA_DEVICE_ID);
    if (!cfg) {
        xil_printf("DMA config not found\r\n");
        return -1;
    }
    XAxiDma_CfgInitialize(&dma, cfg);
    XAxiDma_IntrEnable(&dma,
        XAXIDMA_IRQ_IOC_MASK | XAXIDMA_IRQ_ERROR_MASK,
        XAXIDMA_DEVICE_TO_DMA);

    /* ─ Init GIC + connect DMA IRQ ─ */
    gic_cfg = XScuGic_LookupConfig(INTC_DEVICE_ID);
    XScuGic_CfgInitialize(&gic, gic_cfg, gic_cfg->CpuBaseAddress);
    Xil_ExceptionRegisterHandler(XIL_EXCEPTION_ID_INT,
        (Xil_ExceptionHandler)XScuGic_InterruptHandler, &gic);
    XScuGic_Connect(&gic, DMA_S2MM_IRQ_ID,
        dma_s2mm_handler, NULL);
    XScuGic_Enable(&gic, DMA_S2MM_IRQ_ID);
    Xil_ExceptionEnable();

    /* ─ Mount SD and open file ─ */
    rc = f_mount(&fs, "", 1);
    if (rc) { xil_printf("SD mount failed %d\r\n", rc); return -1; }
    rc = f_open(&fil, OUTPUT_FILE, FA_CREATE_ALWAYS | FA_WRITE);
    if (rc) { xil_printf("File open failed %d\r\n", rc); return -1; }

    xil_printf("Starting capture...\r\n");

    /* ─ Kick off first DMA transfer ─ */
    start_dma(dma_buf);

    /* ─ Ping-pong loop ─────────────────────────────────── */
    while (xfers < NUM_TRANSFERS)
    {
        /* Wait for DMA to finish — interrupt or timeout */
        u32 timeout = 10000000;
        while (!dma_done && !dma_error && timeout > 0) {
            timeout--;
        /* Also poll the status register directly */
         u32 status = XAxiDma_IntrGetIrq(&dma, XAXIDMA_DEVICE_TO_DMA);
         if (status & XAXIDMA_IRQ_IOC_MASK) {
             XAxiDma_IntrAckIrq(&dma, status, XAXIDMA_DEVICE_TO_DMA);
             dma_done = 1;
            }
        if (status & XAXIDMA_IRQ_ERROR_MASK) {
            dma_error = 1;
         }
        }
if (timeout == 0) xil_printf("DMA timeout!\r\n");
        if (dma_error) {
            xil_printf("DMA error at transfer %lu\r\n", xfers);
            break;
        }
        dma_done = 0;
        xfers++;

        /* Swap buffers */
        tmp       = write_buf;
        write_buf = dma_buf;
        dma_buf   = tmp;

        /* Start next DMA immediately if more transfers needed */
        if (xfers < NUM_TRANSFERS)
            start_dma(dma_buf);

        /* Write completed buffer to SD */
        rc = f_write(&fil, write_buf, BUFFER_BYTES, &bw);
        if (rc || bw != (UINT)BUFFER_BYTES)
            xil_printf("Write err %d wrote %u\r\n", rc, bw);
    }

    f_close(&fil);
    f_unmount("");
    xil_printf("Done. %lu transfers written to %s\r\n",
               xfers, OUTPUT_FILE);
    xil_printf("Total bytes: %lu\r\n", xfers * BUFFER_BYTES);
    return 0;
}
